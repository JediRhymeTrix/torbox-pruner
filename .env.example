# TorBox Pruner — environment variables
# Copy this file to .env and fill in your values.
# .env is sourced by run-prune.sh at startup if it exists.
# You can also set these variables in your shell profile or launchd plist.

# ── Required ─────────────────────────────────────────────────────────────────

# Your TorBox API key (Settings → API in the TorBox web UI)
TORBOX_API_KEY=your-torbox-api-key-here

# Your Telegram user/chat ID (the numeric ID Goose paired with)
# Find it by messaging @userinfobot on Telegram
TORBOX_TELEGRAM_CHAT_ID=your-telegram-chat-id-here

# ── Optional ─────────────────────────────────────────────────────────────────

# Telegram bot token — only needed if the auto-detection from the
# macOS Keychain (goose pairing) doesn't work on your machine.
# TORBOX_TELEGRAM_BOT_TOKEN=your-bot-token-here

# Override the install directory (default: directory containing this .env file)
# Useful if you run the script from a different working directory.
# TORBOX_PRUNER_DIR=/path/to/torbox-pruner
